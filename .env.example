# Nebius-managed vLLM (OpenAI-compatible)
NEBIUS_VLLM_BASE_URL=http://<public_ip>:8000
NEBIUS_VLLM_API_KEY=<your_vllm_api_key>
NEBIUS_VLLM_MODEL=nvidia/Cosmos-Reason2-8B
NEBIUS_VLLM_TIMEOUT_S=120

# Optional sampling overrides (defaults follow NVIDIA reason guide)
# NEBIUS_VLLM_TEMPERATURE=0.6
# NEBIUS_VLLM_TOP_P=0.95
# NEBIUS_VLLM_TOP_K=20
# NEBIUS_VLLM_PRESENCE_PENALTY=0.0
# NEBIUS_VLLM_REPETITION_PENALTY=1.0
# NEBIUS_VLLM_MAX_TOKENS=800

# Legacy fallbacks (supported by config loader)
# COSMOS_API_BASE=http://<public_ip>:8000
# COSMOS_API_KEY=<your_vllm_api_key>
# COSMOS_MODEL=nvidia/Cosmos-Reason2-8B
